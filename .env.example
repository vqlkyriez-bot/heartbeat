# Required - Letta
LETTA_API_KEY=
HAL_AGENT_ID=
LETTA_CONVERSATION_ID=

# Optional - Heartbeat interval (default: 30)
HEARTBEAT_INTERVAL_MINUTES=30

# Optional - Oura Ring integration
# Run get_token.py locally once to obtain OURA_REFRESH_TOKEN
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REFRESH_TOKEN=

# Optional - Telegram bot for SEND_TELEGRAM directives
# Get BOT_TOKEN from BotFather on Telegram, CHAT_ID is Lillith's Telegram user ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
